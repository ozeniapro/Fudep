{
  "entities": {
    "NailTechnician": {
      "title": "NailTechnician",
      "description": "Represents a nail technician on the Fudep marketplace.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the technician" },
        "name": { "type": "string", "description": "Display name of the technician" },
        "username": { "type": "string", "description": "Instagram handle style username" },
        "avatar": { "type": "string", "description": "Avatar image URL or placeholder" },
        "city": { "type": "string", "description": "City of service (e.g. Paris)" },
        "bio": { "type": "string", "description": "Professional biography" },
        "rating": { "type": "number", "description": "Average user rating" },
        "reviewsCount": { "type": "number", "description": "Total count of reviews received" },
        "services": { "type": "array", "description": "List of services provided" },
        "tags": { "type": "array", "description": "Specialty hashtags or tags" },
        "freeSlots": { "type": "array", "description": "Open availability slots added by admin" }
      },
      "required": ["id", "name", "username", "avatar", "city", "bio", "rating", "reviewsCount", "services", "tags"]
    },
    "Post": {
      "title": "Post",
      "description": "An inspiration feed post depicting design work.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Post unique ID" },
        "technicianId": { "type": "string", "description": "Associated nail technician ID" },
        "imageUrl": { "type": "string", "description": "URL of the work photograph" },
        "caption": { "type": "string", "description": "Descriptive text caption" },
        "likes": { "type": "number", "description": "Number of favorites/likes" },
        "tags": { "type": "array", "description": "Array of categorized hashtag strings" },
        "date": { "type": "string", "description": "Publish date string" },
        "price": { "type": "number", "description": "Price of the creation in Euros" }
      },
      "required": ["id", "technicianId", "imageUrl", "caption", "likes", "tags", "date"]
    },
    "BookingRequest": {
      "title": "BookingRequest",
      "description": "A client booking reservation request with 30% Stripe deposit.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "technicianId": { "type": "string" },
        "technicianName": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceName": { "type": "string" },
        "price": { "type": "number" },
        "clientFirstName": { "type": "string" },
        "clientPhone": { "type": "string" },
        "clientEmail": { "type": "string" },
        "desiredDate": { "type": "string" },
        "desiredTime": { "type": "string" },
        "alternativeAvailabilities": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "refused", "proposed"] },
        "createdAt": { "type": "string" },
        "depositPaid": { "type": "number" },
        "cardUsed": { "type": "string" },
        "proposedDate": { "type": "string" },
        "modelPhoto": { "type": "string" },
        "postRefId": { "type": "string" }
      },
      "required": ["id", "technicianId", "technicianName", "serviceId", "serviceName", "price", "clientFirstName", "clientPhone", "clientEmail", "desiredDate", "desiredTime", "status", "createdAt"]
    },
    "UserAccount": {
      "title": "UserAccount",
      "description": "A persistent client user account.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "city": { "type": "string" },
        "password": { "type": "string" }
      },
      "required": ["name", "email", "phone", "city"]
    }
  },
  "firestore": {
    "technicians/{id}": {
      "schema": "NailTechnician",
      "description": "Registered and seeded pro nail technicians."
    },
    "posts/{id}": {
      "schema": "Post",
      "description": "Feed gallery of design photographs."
    },
    "bookings/{id}": {
      "schema": "BookingRequest",
      "description": "Customer reservations with status and deposit payment data."
    },
    "booking/{id}": {
      "schema": "BookingRequest",
      "description": "Customer reservations (singular collection alias)."
    },
    "accounts/{email}": {
      "schema": "UserAccount",
      "description": "Users registry keyed by lowercased emails."
    },
    "settings/{documentId}": {
      "schema": "object",
      "description": "Global administration, platform settings, FAQs, and policies."
    }
  }
}
